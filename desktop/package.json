{
  "name": "feiyou-zhijia",
  "version": "1.0.0",
  "description": "飞友之家 - 实时聊天桌面应用",
  "main": "main.js",
  "author": "飞友之家",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win",
    "build:all": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.feiyou.zhijia",
    "productName": "飞友之家",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "飞友之家",
      "installerLanguages": ["zh_CN", "en_US"],
      "unicode": true
    },
    "portable": {
      "artifactName": "飞友之家_便携版_${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
