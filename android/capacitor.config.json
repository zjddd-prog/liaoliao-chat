{
  "appId": "com.feiyou.zhijia",
  "appName": "飞友之家",
  "webDir": "www",
  "server": {
    "url": "https://liaoliao-chat.onrender.com",
    "cleartext": true,
    "allowNavigation": ["liaoliao-chat.onrender.com"]
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#f0f2f5"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#4285f4",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#4285f4"
    }
  }
}
